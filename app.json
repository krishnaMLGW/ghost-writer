{
  "expo": {
    "name": "Ghost Writer",
    "slug": "ghost-writer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ghostwriter.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Ghost Writer needs camera access to take photos for roasting",
        "NSPhotoLibraryUsageDescription": "Ghost Writer needs photo library access to import screenshots and photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.ghostwriter.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-image-picker",
      "expo-asset"
    ]
  }
}
